# URL base da API (sem barra no final)
# Navegador (Expo Web) na mesma maquina:
# EXPO_PUBLIC_URL_BASE_API=http://localhost:3000
# Android emulador: use o IP especial que aponta para o PC hospedeiro
EXPO_PUBLIC_URL_BASE_API=http://localhost:3000
# Dispositivo fisico na mesma rede Wi-Fi: IP da maquina (ex.: http://192.168.1.10:3000)
# iOS simulador: geralmente http://localhost:3000 funciona
